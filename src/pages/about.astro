---
import BaseLayout from '../layouts/BaseLayout.astro';
import AsciiBox from '../components/AsciiBox.astro';
---

<BaseLayout title="About" description="About Zach Keyes — background, studies, and actuarial progress.">

  <h2 class="page-title">// ABOUT</h2>

  <section class="bio-section section">
    <p>
      I'm Zach Keyes, a mathematician and information scientist working toward
      a career in actuarial science. I hold a B.S. in Mathematics and
      Information Science from the University of Arizona, and I'm currently
      completing an accelerated M.S. in Information Science with an emphasis
      in machine learning.
    </p>
    <br />
    <p>
      I'm drawn to the nexus where rigorous quantitative thinking is applied to real-world problems. This requires a solid foundation in theory and problem-solving skills trained through practice, both of which I bring to the table. My machine learning expertise gives me an additional lens for actuarial problems.
    </p>
    <br />
    <p>
      Outside of coursework, I build tools and feed my curiosity of the world and how
      we might model it. I also have many non-professional interests: espresso, bouldering, backpacking, science fiction and classic literature and film, public infrastructure and riding my V13 EUC just to name a few.
    </p>
  </section>

  <section class="section">
    <h3 class="section-heading">// ACTUARIAL PROGRESS</h3>
    <AsciiBox>
      <div class="status-list">
        <div class="status-row">
          <span class="status-label">Exam P</span>
          <span class="status-tag planned">[ planned ]</span>
        </div>
        <div class="status-row">
          <span class="status-label">Exam FM</span>
          <span class="status-tag planned">[ planned ]</span>
        </div>
        <div class="status-row">
          <span class="status-label">Exam FAM</span>
          <span class="status-tag dimmed">[ — ]</span>
        </div>
        <div class="status-row">
          <span class="status-label">VEE Economics</span>
          <span class="status-tag dimmed">[ — ]</span>
        </div>
        <div class="status-row">
          <span class="status-label">VEE Statistics</span>
          <span class="status-tag dimmed">[ — ]</span>
        </div>
        <div class="status-row">
          <span class="status-label">VEE Accounting</span>
          <span class="status-tag dimmed">[ — ]</span>
        </div>
      </div>
      <br />
      <p class="progress-note">
        Planning to register for Exam P and FM. Completed Theory of Probability
        and Theory of Statistics at U of Arizona — the groundwork is there,
        the exams are next.
      </p>
    </AsciiBox>
  </section>

  <section class="section">
    <h3 class="section-heading">// EDUCATION</h3>
    <AsciiBox>
      <div class="edu-entry">
        <p><strong>B.S. Mathematics &amp; Information Science</strong></p>
        <p class="dimmed">University of Arizona</p>
      </div>
      <br />
      <div class="edu-entry">
        <p><strong>M.S. Information Science</strong> <span class="dimmed">(in progress)</span></p>
        <p class="dimmed">University of Arizona — emphasis: machine learning</p>
        <p class="dimmed">Accelerated program</p>
      </div>
    </AsciiBox>
  </section>

  <section class="section">
    <h3 class="section-heading">// SKILLS</h3>
    <AsciiBox>
      <div class="skills-grid">
        <div>
          <p class="label">languages</p>
          <p>Python, R, SQL</p>
        </div>
        <div>
          <p class="label">tools &amp; libraries</p>
          <p>NumPy, Pandas, Scikit-learn, Matplotlib</p>
        </div>
        <div>
          <p class="label">domains</p>
          <p>actuarial science, machine learning, data analysis, probability &amp; statistics</p>
        </div>
      </div>
    </AsciiBox>
  </section>

</BaseLayout>

<style>
.page-title {
  margin-bottom: 2rem;
  color: var(--color-accent-1);
  font-size: 1.2rem;
  letter-spacing: 0.1em;
}

.section-heading {
  color: var(--color-accent-1);
  font-size: 0.95rem;
  letter-spacing: 0.1em;
  margin-bottom: 1rem;
}

.bio-section p {
  max-width: 65ch;
  line-height: 1.7;
}

.status-list {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.status-row {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  font-size: 0.9rem;
}

.status-label {
  min-width: 14ch;
}

.status-tag {
  font-size: 0.85rem;
}

.status-tag.planned {
  color: var(--color-accent-1);
}

.status-tag.dimmed {
  color: var(--color-dimmed, #555);
}

.progress-note {
  font-size: 0.85rem;
  color: var(--color-dimmed, #666);
  line-height: 1.6;
}

.edu-entry {
  margin-bottom: 0.25rem;
}

.skills-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1.5rem;
}

.skills-grid p:not(.label) {
  font-size: 0.9rem;
  margin-top: 0.25rem;
}
</style>
